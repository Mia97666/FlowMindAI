.group-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: var(--space-lg); background: var(--color-card);
  border-radius: var(--radius-lg); margin-bottom: var(--space-md);
  box-shadow: var(--shadow-sm);
}
.group-name { font-size: 16px; font-weight: 600; display: block; }
.group-meta { font-size: 13px; color: var(--color-muted-fg); display: block; margin-top: 2px; }
