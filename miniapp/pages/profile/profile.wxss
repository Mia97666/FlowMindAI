.page-header{display:flex;align-items:center;padding:12px var(--space-lg);min-height:48px;background:var(--color-bg)}
.title{font-size:18px;font-weight:700;flex:1}
.content{padding:0 var(--space-lg)}
.safe{height:calc(100vh - 64px);box-sizing:border-box}
.profile-card{display:flex;align-items:center;gap:var(--space-lg);padding:var(--space-xl);background:var(--color-card);border-radius:var(--radius-lg);box-shadow:var(--shadow-sm);margin-bottom:var(--space-lg)}
.pname{font-size:20px;font-weight:700;display:block}
.pid{font-size:14px;color:var(--color-muted-fg);display:block}
.profile-safe { width: 100%; }
.edit-profile-btn { font-size: 14px; color: var(--color-primary); font-weight: 600; }

/* ★ 当日总分 */
.today-score-box {
  display: flex; align-items: center; gap: 8px; margin-top: 8px;
  padding: 6px 12px; background: var(--color-muted); border-radius: var(--radius-md);
}
.today-label { font-size: 13px; color: var(--color-muted-fg); font-weight: 500; }
.today-val { font-size: 18px; font-weight: 800; font-family: var(--font-mono); }

/* ★ 今日好友排行 */
.today-rank-box { display: flex; align-items: center; gap: 8px; margin-top: 6px; padding: 4px 12px; background: var(--color-muted); border-radius: var(--radius-md); }
.today-rank-label { font-size: 12px; color: var(--color-muted-fg); font-weight: 500; }
.today-rank-val { font-size: 14px; font-weight: 700; color: var(--color-accent); }

/* ★ 底部调皮话 */
.footer-quote { text-align: center; padding: 24px 0 100px; font-size: 13px; color: var(--color-muted-fg); letter-spacing: 1px; }

/* 隐藏不再直接展示的麻神排行区域（已改为按钮跳转） */
.ranking-section { display: none; }

/* ★ 麻神排行区域 */
.ranking-section { margin-bottom: var(--space-lg); }
.section-title-lg { font-size: 20px; font-weight: 700; display: block; margin-bottom: var(--space-md); }
.ranking-card {
  background: var(--color-card); border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm); padding: var(--space-lg); margin-bottom: var(--space-md);
}
.ranking-card-title { font-size: 17px; font-weight: 700; display: block; margin-bottom: var(--space-md); }
.empty-ranking { text-align: center; padding: var(--space-xl); color: var(--color-muted-fg); font-size: 14px; }

/* ★ 冠军特殊展示 */
.champion-box {
  display: flex; align-items: center; gap: var(--space-md);
  padding: 16px; margin-bottom: var(--space-md);
  background: linear-gradient(135deg, rgba(217,119,6,0.12) 0%, rgba(217,119,6,0.04) 100%);
  border: 1px solid rgba(217,119,6,0.2);
  border-radius: var(--radius-lg); position: relative;
}
.champion-crown { font-size: 28px; position: absolute; top: -8px; left: 12px; }
.champion-avatar { margin-top: 8px; }
.champion-info { flex: 1; }
.champion-name { font-size: 18px; font-weight: 700; display: block; }
.champion-group { font-size: 12px; color: var(--color-muted-fg); display: block; margin-top: 2px; }
.champion-score { font-size: 24px; font-weight: 800; font-family: var(--font-mono); }

/* ★ 普通排名行 */
.rank-row {
  display: flex; align-items: center; gap: var(--space-md);
  padding: 10px 0; border-bottom: 1px solid var(--color-border);
}
.rank-row:last-child { border-bottom: none; }
.rank-num { width: 24px; font-size: 16px; font-weight: 700; color: var(--color-muted-fg); text-align: center; }
.rank-info { flex: 1; }
.rank-name { font-size: 15px; font-weight: 600; display: block; }
.rank-group { font-size: 12px; color: var(--color-muted-fg); display: block; }
.rank-score { font-size: 17px; font-weight: 700; font-family: var(--font-mono); }

.menu-list{background:var(--color-card);border-radius:var(--radius-lg);box-shadow:var(--shadow-sm);overflow:hidden;margin-bottom:var(--space-lg)}
.menu-item{display:flex;align-items:center;justify-content:space-between;padding:var(--space-lg);border-bottom:1px solid var(--color-border);font-size:16px}
.menu-item:last-child{border-bottom:none}
.ml{display:flex;align-items:center;gap:var(--space-md)}
.mi{width:40px;height:40px;border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;font-size:18px}
/* ★ SVG 图标 */
.mi-svg{width:22px;height:22px}
.ma{color:var(--color-muted-fg);font-size:16px}
.theme-opts{display:flex;align-items:center;gap:6px}
.to{font-size:13px;padding:5px 12px;border-radius:14px;color:var(--color-muted-fg)}
.to.on{background:var(--color-primary);color:#FFF;font-weight:600}

.tab-bar{display:flex;align-items:center;justify-content:space-evenly;background:var(--color-card);border-top:1px solid var(--color-border);position:fixed;bottom:0;left:0;right:0;height:64px;z-index:50;padding-bottom:env(safe-area-inset-bottom,0)}
.tab-item{display:flex;align-items:center;justify-content:center;color:var(--color-muted-fg);font-size:16px;font-weight:500;padding:10px 26px;border-radius:22px}
.tab-item.active{background:var(--color-primary);color:#FFF;font-weight:600}
