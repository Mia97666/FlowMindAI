/* 麻神排行页面 */
.page-header {
  display: flex; align-items: center; padding: 12px var(--space-lg);
  gap: 14px; min-height: 48px; background: var(--color-bg);
}
.back-btn {
  width: 44px; height: 44px; border-radius: 50%; display: flex;
  align-items: center; justify-content: center; background: var(--color-muted);
  color: var(--color-card-fg); font-size: 20px; font-weight: 700;
}
.title { font-size: 18px; font-weight: 700; flex: 1; }

.ranking-tabs {
  display: flex; background: var(--color-muted); border-radius: var(--radius-md);
  padding: 4px; gap: 4px; margin: 0 var(--space-lg) var(--space-lg);
}
.ranking-tab {
  flex: 1; border-radius: 7px; padding: 12px 0; text-align: center;
  font-size: 15px; font-weight: 600; color: var(--color-muted-fg);
  transition: all var(--transition);
}
.ranking-tab.active {
  background: var(--color-card); color: var(--color-card-fg);
  box-shadow: var(--shadow-sm);
}

.content { padding: 0 var(--space-lg); }
.safe { height: calc(100vh - 64px); box-sizing: border-box; }

/* ★ 冠军特殊展示 */
.champion-box {
  display: flex; align-items: center; gap: var(--space-md);
  padding: 20px; margin-bottom: var(--space-md);
  background: linear-gradient(135deg, rgba(217,119,6,0.15) 0%, rgba(217,119,6,0.04) 100%);
  border: 1px solid rgba(217,119,6,0.25); border-radius: var(--radius-xl);
  position: relative; overflow: hidden;
}
.champion-crown { font-size: 32px; position: absolute; top: -6px; left: 16px; }
.champion-avatar { margin-top: 12px; border: 3px solid rgba(217,119,6,0.5); }
.champion-info { flex: 1; }
.champion-name { font-size: 20px; font-weight: 700; display: block; }
.champion-group { font-size: 12px; color: var(--color-muted-fg); display: block; margin-top: 2px; }
.champion-score { font-size: 28px; font-weight: 800; font-family: var(--font-mono); }

/* 普通排名行 */
.rank-row {
  display: flex; align-items: center; gap: var(--space-md);
  padding: 14px 12px; margin-bottom: 8px;
  background: var(--color-card); border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}
.rank-num { width: 28px; font-size: 16px; font-weight: 700; color: var(--color-muted-fg); text-align: center; }
.rank-info { flex: 1; }
.rank-name { font-size: 15px; font-weight: 600; display: block; }
.rank-group { font-size: 12px; color: var(--color-muted-fg); display: block; }
.rank-score { font-size: 18px; font-weight: 700; font-family: var(--font-mono); }

.empty-state { text-align: center; padding: 40px 0; color: var(--color-muted-fg); font-size: 14px; }

/* ★ 生涯弹窗 */
.career-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.55); display: flex; align-items: center;
  justify-content: center; z-index: 1000;
}
.career-popup {
  width: 85%; max-width: 360px; background: var(--color-card);
  border-radius: var(--radius-xl); padding: var(--space-xl);
  box-shadow: 0 20px 60px rgba(0,0,0,0.35);
}
.career-header { display: flex; align-items: center; gap: var(--space-md); margin-bottom: var(--space-lg); }
.career-name { font-size: 18px; font-weight: 700; }
.career-stats {
  display: flex; flex-wrap: wrap; gap: var(--space-md); margin-bottom: var(--space-lg);
}
.career-stat {
  flex: 1; min-width: 80px; text-align: center;
  padding: 12px 8px; background: var(--color-muted); border-radius: var(--radius-md);
}
.career-stat-val { font-size: 20px; font-weight: 800; display: block; font-family: var(--font-mono); }
.career-stat-label { font-size: 12px; color: var(--color-muted-fg); display: block; margin-top: 2px; }

.btn-danger {
  background: #DC2626; color: #FFF; border: none; border-radius: var(--radius-md);
  font-size: 15px; font-weight: 600; padding: 12px 0;
}
.btn-block { width: 100%; }
