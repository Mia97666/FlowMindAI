<view class="page-fade-in theme-root {{theme === 'light' ? 'theme-light' : ''}}">

  <!-- 顶部导航 -->
  <view class="page-header" style="padding-top:{{safeTop}}px">
    <view class="back-btn" bindtap="onGoBack">←</view>
    <text class="title">麻神排行</text>
    <view></view>
  </view>

  <!-- Tab 切换 -->
  <view class="ranking-tabs">
    <view class="ranking-tab {{currentTab === 'today' ? 'active' : ''}}" bindtap="onTabTap" data-tab="today">🔥 当日麻神</view>
    <view class="ranking-tab {{currentTab === 'total' ? 'active' : ''}}" bindtap="onTabTap" data-tab="total">⭐ 总计麻神</view>
  </view>

  <scroll-view scroll-y class="content safe">

    <!-- 当日麻神 -->
    <view wx:if="{{currentTab === 'today'}}">
      <view wx:if="{{todayList.length > 0}}">
        <!-- ★ 冠军特殊展示 -->
        <view class="champion-box">
          <view class="champion-crown">👑</view>
          <view class="avatar avatar-xl champion-avatar" style="background:{{todayList[0].avatarColor}}">{{todayList[0].avatar}}</view>
          <view class="champion-info">
            <text class="champion-name">{{todayList[0].nickname}}</text>
            <text wx:if="{{todayList[0].groupName}}" class="champion-group">{{todayList[0].groupName}}</text>
          </view>
          <text class="champion-score" style="color:{{todayList[0].score >= 0 ? 'var(--color-danger)' : 'var(--color-success)'}}">{{todayList[0].scoreStr}}</text>
        </view>
        <!-- 其余排名 -->
        <view class="rank-row" wx:for="{{todayList}}" wx:key="userId" wx:if="{{index > 0}}">
          <text class="rank-num">{{item.rank}}</text>
          <view class="avatar avatar-md" style="background:{{item.avatarColor}}" bindtap="onAvatarTap" data-user="{{item}}">{{item.avatar}}</view>
          <view class="rank-info">
            <text class="rank-name">{{item.nickname}}</text>
            <text wx:if="{{item.groupName}}" class="rank-group">{{item.groupName}}</text>
          </view>
          <text class="rank-score" style="color:{{item.score >= 0 ? 'var(--color-danger)' : 'var(--color-success)'}}">{{item.scoreStr}}</text>
        </view>
      </view>
      <view wx:else class="empty-state">暂无数据</view>
    </view>

    <!-- 总计麻神 -->
    <view wx:if="{{currentTab === 'total'}}">
      <view wx:if="{{totalList.length > 0}}">
        <!-- ★ 冠军特殊展示 -->
        <view class="champion-box">
          <view class="champion-crown">👑</view>
          <view class="avatar avatar-xl champion-avatar" style="background:{{totalList[0].avatarColor}}">{{totalList[0].avatar}}</view>
          <view class="champion-info">
            <text class="champion-name">{{totalList[0].nickname}}</text>
            <text wx:if="{{totalList[0].groupName}}" class="champion-group">{{totalList[0].groupName}}</text>
          </view>
          <text class="champion-score" style="color:{{totalList[0].score >= 0 ? 'var(--color-danger)' : 'var(--color-success)'}}">{{totalList[0].scoreStr}}</text>
        </view>
        <!-- 其余排名 -->
        <view class="rank-row" wx:for="{{totalList}}" wx:key="userId" wx:if="{{index > 0}}">
          <text class="rank-num">{{item.rank}}</text>
          <view class="avatar avatar-md" style="background:{{item.avatarColor}}" bindtap="onAvatarTap" data-user="{{item}}">{{item.avatar}}</view>
          <view class="rank-info">
            <text class="rank-name">{{item.nickname}}</text>
            <text wx:if="{{item.groupName}}" class="rank-group">{{item.groupName}}</text>
          </view>
          <text class="rank-score" style="color:{{item.score >= 0 ? 'var(--color-danger)' : 'var(--color-success)'}}">{{item.scoreStr}}</text>
        </view>
      </view>
      <view wx:else class="empty-state">暂无数据</view>
    </view>

  </scroll-view>

  <!-- ★ 生涯弹窗 -->
  <view wx:if="{{showCareer}}" class="career-mask" bindtap="onCloseCareer">
    <view class="career-popup" catchtap="stopPropagation">
      <view class="career-header">
        <view class="avatar avatar-xl" style="background:{{careerUser.avatarColor}}">{{careerUser.avatar}}</view>
        <text class="career-name">{{careerUser.nickname}}</text>
      </view>
      <view class="career-stats" wx:if="{{careerStats}}">
        <view class="career-stat">
          <text class="career-stat-val">{{careerStats.totalGames}}</text>
          <text class="career-stat-label">总局数</text>
        </view>
        <view class="career-stat">
          <text class="career-stat-val">{{careerStats.totalWins}}</text>
          <text class="career-stat-label">总胜场</text>
        </view>
        <view class="career-stat">
          <text class="career-stat-val">{{careerStats.winRate}}%</text>
          <text class="career-stat-label">胜率</text>
        </view>
        <view class="career-stat">
          <text class="career-stat-val">{{careerStats.totalScoreStr}}</text>
          <text class="career-stat-label">总分</text>
        </view>
        <view class="career-stat">
          <text class="career-stat-val">{{careerStats.maxScoreStr}}</text>
          <text class="career-stat-label">最高得分</text>
        </view>
      </view>
      <button class="btn btn-danger btn-block" bindtap="onDeleteFriend">删除好友</button>
    </view>
  </view>

</view>
