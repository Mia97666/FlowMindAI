<view class="page-fade-in theme-root {{theme === 'light' ? 'theme-light' : ''}}">
  <view class="page-header" style="padding-top:{{safeTop}}px">
    <view class="back-btn" bindtap="onBack">←</view>
    <text class="title">个人战绩</text>
    <view></view>
  </view>

  <scroll-view scroll-y class="content">
    <!-- ★ 年/月筛选 -->
    <view class="filter-bar">
      <picker mode="selector" range="{{yearOptions}}" bindchange="onYearChange">
        <view class="filter-btn">{{filterYear ? filterYear + '年' : '全部年份 ▾'}}</view>
      </picker>
      <picker mode="selector" range="{{monthOptions}}" bindchange="onMonthChange">
        <view class="filter-btn">{{filterMonth ? filterMonth + '月' : '全部月份 ▾'}}</view>
      </picker>
      <view class="filter-reset" bindtap="onResetFilter">重置</view>
    </view>

    <!-- ★ 总分 — 大卡片突出展示 -->
    <view class="sum-card">
      <text class="sum-label">总分</text>
      <text class="sum-value" style="color:{{stats.sum >= 0 ? 'var(--color-danger)' : 'var(--color-success)'}}">{{stats.sumStr}}</text>
    </view>

    <!-- ★ 统计项 -->
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-val">{{stats.total}}</text>
        <text class="stat-lbl">总局数</text>
      </view>
      <view class="stat-item">
        <text class="stat-val" style="color:var(--color-danger)">{{stats.wins}}</text>
        <text class="stat-lbl">总胜数</text>
      </view>
      <view class="stat-item">
        <text class="stat-val" style="color:var(--color-accent)">{{stats.rate}}%</text>
        <text class="stat-lbl">胜率</text>
      </view>
      <view class="stat-item">
        <text class="stat-val" style="color:var(--color-danger)">{{stats.highestScoreStr}}</text>
        <text class="stat-lbl">最高分</text>
      </view>
    </view>

    <!-- ★ 历史牌局 -->
    <view class="card">
      <view class="card-top-row">
        <text class="card-title">历史牌局</text>
        <view class="sort-btns">
          <text class="sort-btn {{historySort === 'date' ? 'active' : ''}}" bindtap="onSortChange" data-sort="date">按日期</text>
          <text class="sort-btn {{historySort === 'score' ? 'active' : ''}}" bindtap="onSortChange" data-sort="score">按得分</text>
        </view>
      </view>

      <view wx:if="{{history.length === 0}}" class="empty-state">暂无牌局记录</view>

      <view wx:for="{{history}}" wx:key="id" class="h-item" bindtap="onTap" data-id="{{item.id}}">
        <view class="h-left">
          <text class="h-name">{{item.name}}</text>
          <text class="h-meta">
            {{item.date}} · {{item.rounds}}局
            <text wx:if="{{item.multEnabled}}" style="color:var(--color-accent)"> · 倍率×{{item.multiplier}}</text>
          </text>
        </view>
        <text class="h-score" style="color:{{item.myScore >= 0 ? 'var(--color-danger)' : 'var(--color-success)'}}">{{item.myScoreStr}}</text>
      </view>
    </view>

    <!-- ★ 底部调皮语 -->
    <view class="footer-msg">{{footerMsg}}</view>

    <!-- ★ 分享按钮 -->
    <button class="btn btn-primary share-btn" open-type="share">📤 分享战绩给好友</button>

  </scroll-view>
</view>
