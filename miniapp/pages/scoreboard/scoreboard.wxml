<view class="page-fade-in theme-root {{theme === 'light' ? 'theme-light' : ''}}">
  <view class="page-header" style="padding-top:{{safeTop}}px">
    <view class="back-btn" bindtap="onBack">←</view>
    <text class="title">{{room.name}}</text>
    <view class="closed-badge">已收盘</view>
  </view>

  <scroll-view scroll-y class="content" wx:if="{{room}}">
    <view class="card">
      <text class="card-title-lg mb-lg" style="text-align:center">🏆 最终成绩</text>
      <text wx:if="{{room.multiplierEnabled}}" style="text-align:center;font-size:13px;color:var(--color-accent);display:block;margin-top:-12px;margin-bottom:12px">
        ⚡ 倍率 ×{{room.multiplier}}
      </text>
      <view class="final-scores">
        <view class="fs-item" wx:for="{{ranked}}" wx:key="id">
          <view class="avatar avatar-lg" style="background:{{item.color}};margin:0 auto 10px">{{item.avatar}}</view>
          <text style="font-weight:700;font-size:16px">{{item.name}}</text>
          <text class="fs-val" style="color:{{item.totalScore >= 0 ? 'var(--color-danger)' : 'var(--color-success)'}}">{{item.totalScoreStr}}</text>
        </view>
      </view>
    </view>

    <view class="card">
      <text class="card-title-lg" style="margin-bottom:24px">📋 对局历史（共{{rounds.length}}局）</text>
      <view class="history-header">
        <view style="display:flex;justify-content:space-around">
          <view class="avatar avatar-md" wx:for="{{room.players}}" wx:key="id" style="background:{{item.color}}">{{item.avatar}}</view>
        </view>
      </view>
      <view class="history-round" wx:for="{{rounds}}" wx:key="roundNumber">
        <view class="round-info">
          <text style="font-weight:600;font-size:14px">第{{item.roundNumber}}局</text>
          <text style="font-size:13px;color:var(--color-muted-fg)">{{item.timeStr}}</text>
        </view>
        <view class="round-scores">
          <view class="round-score-lg" wx:for="{{room.players}}" wx:for-item="p" wx:key="id" style="color:{{(item.scores[p.id]||0)>0?'var(--color-danger)':(item.scores[p.id]||0)<0?'var(--color-success)':'var(--color-muted-fg)'}};border-bottom:3px solid {{p.color}}">
            {{item.scoreStrs[p.id]}}
          </view>
        </view>
      </view>
    </view>

    <text style="text-align:center;font-size:12px;color:var(--color-muted-fg);display:block;margin:16px 0">
      收盘时间：{{room.closedAtStr}}
      <text wx:if="{{room.multiplierEnabled}}" style="color:var(--color-accent)"> · 倍率 ×{{room.multiplier}}</text>
    </text>
    <button class="btn btn-secondary btn-block" bindtap="onShare">📸 截图分享</button>
  </scroll-view>
</view>
