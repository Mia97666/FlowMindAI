<view class="page-fade-in theme-root {{theme === 'light' ? 'theme-light' : ''}}">
  <!-- 顶部导航 -->
  <view class="groups-header" style="padding-top:{{safeTop}}px">
    <view class="back-btn" bindtap="onBack">←</view>
    <text class="title">固定小组管理</text>
    <view class="header-spacer"></view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <button class="btn-clear-all" bindtap="onClearAll">一键清空</button>
    <button class="btn-batch-del" bindtap="onToggleEdit">{{editing ? '完成' : '批量删除'}}</button>
  </view>

  <!-- 编辑模式工具栏 -->
  <view wx:if="{{editing}}" class="edit-bar">
    <text class="select-all-txt" bindtap="onSelectAll">
      {{selectedIds.length === groups.length ? '取消全选' : '全选'}}
    </text>
    <text class="selected-count">已选择 {{selectedIds.length}} 项</text>
    <button class="btn-confirm-del" bindtap="onDeleteSelected" disabled="{{selectedIds.length === 0}}">删除</button>
  </view>

  <scroll-view scroll-y class="groups-content">
    <view wx:if="{{groups.length === 0}}" class="empty-state">暂无固定小组</view>

    <view wx:for="{{groups}}" wx:key="id" class="group-item {{editing ? 'editing' : ''}}">
      <!-- 左侧复选框(编辑模式) — catchtap 防止冒泡 -->
      <view wx:if="{{editing}}" class="item-check" catchtap="onToggleSelect" data-id="{{item.id}}">
        <view wx:if="{{!item.selected}}" class="check-square"></view>
        <view wx:else class="check-square checked">
          <text class="check-mark">✓</text>
        </view>
      </view>

      <!-- 主体信息 — 编辑模式下不绑定事件 -->
      <view class="item-body">
        <view class="item-top">
          <text class="item-name">{{item.name}}</text>
          <view wx:if="{{item.hasActive}}" class="status-badge active">进行中</view>
        </view>
        <text class="item-meta">{{item.members.length}}人 · {{item.date}}</text>
      </view>

      <!-- 右侧操作 -->
      <view class="item-actions" wx:if="{{!editing}}">
        <text class="action-edit" bindtap="onRename" data-idx="{{index}}" data-name="{{item.name}}">✎ 修改</text>
      </view>
    </view>
  </scroll-view>
</view>
