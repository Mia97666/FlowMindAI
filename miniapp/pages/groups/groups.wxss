/* 固定小组管理 */
.groups-header {
  display: flex; align-items: center; padding: 0 var(--space-lg);
  min-height: 48px; background: var(--color-bg); gap: 14px;
}
.header-spacer { width: 44px; flex-shrink: 0; }

/* 操作按钮栏 */
.action-bar {
  display: flex; gap: 12px; padding: 14px var(--space-lg);
}
.btn-clear-all {
  background: var(--color-danger); color: #FFF; border: none;
  font-size: 15px; font-weight: 600; border-radius: 10px;
  padding: 12px 24px; line-height: 1.3;
}
.btn-batch-del {
  background: var(--color-card); color: var(--color-card-fg);
  border: 1px solid var(--color-border); font-size: 15px;
  font-weight: 600; border-radius: 10px; padding: 12px 24px;
  line-height: 1.3;
}

/* 编辑模式提示栏 */
.edit-bar {
  display: flex; align-items: center; gap: 14px;
  padding: 12px var(--space-lg); margin-bottom: 8px;
}
.select-all-txt {
  font-size: 15px; color: var(--color-primary); font-weight: 600;
}
.selected-count {
  font-size: 14px; color: var(--color-muted-fg); flex: 1;
}
.btn-confirm-del {
  background: var(--color-danger); color: #FFF; border: none;
  font-size: 14px; font-weight: 600; border-radius: 8px;
  padding: 8px 18px; line-height: 1.3;
}
.btn-confirm-del[disabled] { opacity: 0.4; }

/* 列表 */
.groups-content { padding: 0 var(--space-lg); height: calc(100vh - 150px); }

.group-item {
  display: flex; align-items: center; padding: 16px var(--space-lg);
  background: var(--color-card); border-radius: var(--radius-md);
  margin-bottom: 10px; box-shadow: var(--shadow-sm); gap: 14px;
}
.group-item.editing { padding-left: var(--space-md); }

/* 方形复选框 */
.item-check { flex-shrink: 0; }
.check-square {
  width: 24px; height: 24px; border-radius: 5px;
  border: 2px solid var(--color-border); transition: all 0.15s;
}
.check-square.checked {
  background: var(--color-primary); border-color: var(--color-primary);
}
.check-mark {
  color: #FFF; font-size: 16px; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  width: 100%; height: 100%;
}

/* 主体 */
.item-body { flex: 1; min-width: 0; }
.item-top { display: flex; align-items: center; gap: 10px; margin-bottom: 4px; }
.item-name { font-weight: 600; font-size: 16px; }
.item-meta { font-size: 13px; color: var(--color-muted-fg); }

/* 状态标签 */
.status-badge {
  font-size: 12px; font-weight: 600; padding: 3px 10px;
  border-radius: 10px; line-height: 1.5;
}
.status-badge.active {
  background: rgba(21,128,61,0.12); color: var(--color-success);
}

/* 右侧操作 */
.item-actions { flex-shrink: 0; }
.action-edit { font-size: 14px; color: var(--color-primary); font-weight: 600; }

/* 共享样式 */
.back-btn {
  width: 44px; height: 44px; border-radius: 50%; display: flex;
  align-items: center; justify-content: center;
  background: var(--color-muted); color: var(--color-card-fg);
  font-size: 20px; font-weight: 700; flex-shrink: 0;
}
.title { font-size: 18px; font-weight: 700; flex: 1; }
