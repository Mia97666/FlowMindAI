.page-header{display:flex;align-items:center;padding:12px var(--space-lg);min-height:48px;background:var(--color-bg)}
.title{font-size:18px;font-weight:700;flex:1}
.content{padding:0 var(--space-lg)}
.safe{padding-bottom:calc(80px + var(--space-3xl));min-height:100vh;box-sizing:border-box}
.game-card{background:var(--color-card);border-radius:var(--radius-lg);padding:var(--space-lg);margin-bottom:var(--space-md);box-shadow:var(--shadow-sm)}
.game-card:active{opacity:.85}
.card-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-md)}
.scores-row{display:flex;justify-content:space-between;margin-bottom:var(--space-sm)}
.score-cell{text-align:center;flex:1}

/* ★ 年/月筛选 */
.filter-bar{display:flex;align-items:center;gap:6px;flex-shrink:0}
.filter-btn{font-size:12px;padding:4px 10px;border-radius:12px;background:var(--color-muted);color:var(--color-muted-fg);white-space:nowrap}
.filter-reset{font-size:12px;color:var(--color-danger);padding:4px 6px}

.tab-bar{display:flex;align-items:center;justify-content:space-evenly;background:var(--color-card);border-top:1px solid var(--color-border);position:fixed;bottom:0;left:0;right:0;height:64px;z-index:50;padding-bottom:env(safe-area-inset-bottom,0)}
.tab-item{display:flex;align-items:center;justify-content:center;color:var(--color-muted-fg);font-size:16px;font-weight:500;padding:10px 26px;border-radius:22px}
.tab-item.active{background:var(--color-primary);color:#FFF;font-weight:600}
