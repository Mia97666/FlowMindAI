<view class="page-fade-in theme-root {{theme === 'light' ? 'theme-light' : ''}}">
  <view class="page-header" style="padding-top:{{safeTop}}px">
    <text class="title">牌局</text>
    <!-- ★ 年/月筛选 -->
    <view class="filter-bar">
      <picker mode="selector" range="{{yearOptions}}" bindchange="onYearChange">
        <view class="filter-btn">{{filterYear ? filterYear + '年' : '全部年份 ▾'}}</view>
      </picker>
      <picker mode="selector" range="{{monthOptions}}" bindchange="onMonthChange">
        <view class="filter-btn">{{filterMonth ? filterMonth + '月' : '全部月份 ▾'}}</view>
      </picker>
      <view wx:if="{{filterYear || filterMonth}}" class="filter-reset" bindtap="onResetFilter">重置</view>
    </view>
  </view>

  <scroll-view scroll-y class="content safe">
    <view class="segmented">
      <view class="seg-item {{filter === 'active' ? 'active' : ''}}" bindtap="onFilter" data-filter="active">进行中</view>
      <view class="seg-item {{filter === 'closed' ? 'active' : ''}}" bindtap="onFilter" data-filter="closed">已结束</view>
    </view>

    <view wx:if="{{list.length === 0}}" class="empty-state">暂无牌局</view>

    <view wx:for="{{list}}" wx:key="id" class="game-card" bindtap="onTap" data-id="{{item.id}}" data-status="{{item.status}}">
      <view class="card-top">
        <text style="font-weight:700;font-size:16px">{{item.name}}</text>
        <text style="font-size:11px;color:var(--color-muted-fg)">{{item.status === 'active' ? '🟢 进行中' : '🏁 已结束'}}</text>
      </view>
      <view class="scores-row">
        <view class="score-cell" wx:for="{{item.displayPlayers}}" wx:key="id">
          <view class="avatar avatar-sm" style="background:{{item.color}};margin:0 auto 6px">{{item.avatar}}</view>
          <text style="font-family:var(--font-mono);font-size:15px;font-weight:700;color:{{item.totalScore >= 0 ? 'var(--color-danger)' : 'var(--color-success)'}}">{{item.totalScoreStr}}</text>
        </view>
      </view>
      <text style="font-size:12px;color:var(--color-muted-fg)">{{item.timeStr}} · 共{{item.roundCount}}局</text>
    </view>
  </scroll-view>

  <view class="tab-bar">
    <view class="tab-item" bindtap="onTab" data-tab="index">首页</view>
    <view class="tab-item active">牌局</view>
    <view class="tab-item" bindtap="onTab" data-tab="profile">我的</view>
  </view>
</view>
