/* ============================================================
   CSS Variables — 双主题系统（严格参考 index.html）
   ============================================================ */
page, view, text, image, scroll-view, swiper, swiper-item,
input, textarea, button, checkbox, radio, picker, form,
navigator, video, canvas, map, web-view, block, cover-view,
cover-image, movable-view, movable-area, rich-text,
progress, slider, switch, label, picker-view, picker-view-column,
icon, open-data {
  box-sizing: border-box;
}

page {
  --color-primary: #15803D; --color-primary-hover: #166534; --color-on-primary: #FFFFFF;
  --color-accent: #D97706; --color-accent-hover: #B45309; --color-on-accent: #FFFFFF;
  --color-success: #15803D; --color-danger: #DC2626; --color-danger-hover: #B91C1C;
  --color-ring: #15803D;
  --radius-sm: 8px; --radius-md: 12px; --radius-lg: 16px; --radius-xl: 20px; --radius-pill: 26px;
  --space-xs: 4px; --space-sm: 8px; --space-md: 12px; --space-lg: 16px; --space-xl: 20px; --space-2xl: 24px; --space-3xl: 32px;
  --font-mono: 'SF Mono', 'Menlo', monospace;
  --transition: 0.15s ease;
  --color-bg: #0F172A; --color-card: #192134; --color-card-fg: #F1F5F9;
  --color-muted: #1E293B; --color-muted-fg: #94A3B8;
  --color-border: rgba(255,255,255,0.08); --color-surface: #192134;
  --color-overlay: rgba(0,0,0,0.65);
  --shadow-sm: 0 1px 3px rgba(0,0,0,0.3); --shadow-md: 0 4px 12px rgba(0,0,0,0.4); --shadow-lg: 0 8px 24px rgba(0,0,0,0.5);
  --input-bg: #0F172A; --color-overlay-light: rgba(0,0,0,0.5);
}

/* Light theme — applied via CSS class on root view */
.theme-light {
  --color-bg: #F8FAFC; --color-card: #FFFFFF; --color-card-fg: #0F172A;
  --color-muted: #F1F5F9; --color-muted-fg: #64748B;
  --color-border: #E2E8F0; --color-surface: #FFFFFF;
  --color-overlay: rgba(15,23,42,0.35);
  --shadow-sm: 0 1px 2px rgba(0,0,0,0.04),0 1px 3px rgba(0,0,0,0.06);
  --shadow-md: 0 4px 6px rgba(0,0,0,0.04),0 2px 16px rgba(0,0,0,0.06);
  --shadow-lg: 0 10px 25px rgba(0,0,0,0.06),0 4px 10px rgba(0,0,0,0.04);
  --input-bg: #F1F5F9; --color-overlay-light: rgba(15,23,42,0.25);
}

page {
  font-family: 'PingFang SC', 'Microsoft YaHei', system-ui, sans-serif;
  font-size: 15px; background: var(--color-bg); color: var(--color-card-fg);
}

/* Theme root — fills entire page so CSS vars cascade to all children */
.theme-root {
  min-height: 100vh;
  background: var(--color-bg);
  color: var(--color-card-fg);
}

/* Shared Classes */
.card {
  background: var(--color-card); border-radius: var(--radius-lg);
  padding: var(--space-lg); box-shadow: var(--shadow-sm);
  margin-bottom: var(--space-md);
}
.card-title { font-size: 15px; font-weight: 600; }
.card-title.mb-md { margin-bottom: var(--space-md); }

.btn {
  display: flex; align-items: center; justify-content: center; gap: 6px;
  border: none; font-weight: 600; border-radius: var(--radius-pill);
  font-size: 15px; transition: all 0.15s; padding: 13px 24px; height: 50px;
}
.btn-primary { background: var(--color-primary); color: var(--color-on-primary); }
.btn-accent { background: var(--color-accent); color: #FFF; }
.btn-secondary { background: var(--color-card); color: var(--color-card-fg); border: 1px solid var(--color-border); }
.btn-danger { background: var(--color-danger); color: #FFF; font-size: 13px; height: 34px; border-radius: var(--radius-md); padding: 8px 16px; }
.btn-ghost { background: transparent; color: var(--color-muted-fg); padding: 6px 10px; font-size: 12px; height: 28px; border-radius: var(--radius-sm); }
.btn-sm { padding: 6px 12px; font-size: 12px; height: 30px; border-radius: var(--radius-sm); }
.btn-block { width: 100%; }

.avatar {
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-weight: 700; color: #FFF; flex-shrink: 0; position: relative;
}
.avatar-sm { width: 30px; height: 30px; font-size: 12px; }
.avatar-md { width: 42px; height: 42px; font-size: 15px; }
.avatar-lg { width: 56px; height: 56px; font-size: 20px; }
.avatar-xl { width: 64px; height: 64px; font-size: 24px; }

.empty-state {
  text-align: center; padding: var(--space-3xl) var(--space-lg);
  color: var(--color-muted-fg); font-size: 14px;
}

.segmented {
  display: flex; background: var(--color-muted); border-radius: var(--radius-md);
  padding: 3px; gap: 3px; margin-bottom: var(--space-md);
}
.seg-item {
  flex: 1; border-radius: 7px; padding: 9px 0; text-align: center;
  font-size: 14px; font-weight: 500; color: var(--color-muted-fg);
  transition: all var(--transition);
}
.seg-item.active { background: var(--color-card); color: var(--color-card-fg); box-shadow: var(--shadow-sm); }

/* Page transition */
.page-fade-in { animation: pageIn 0.25s ease; }
@keyframes pageIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }
